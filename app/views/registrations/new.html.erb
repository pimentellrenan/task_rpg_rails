<section class="grid min-h-screen place-items-center px-4">
  <div class="w-full max-w-md rounded-md border-2 border-[#17201d] bg-white p-6 shadow-[8px_8px_0_#f0a202]">
    <p class="text-sm font-bold uppercase tracking-wide text-[#1f7a8c]">Primeira missao</p>
    <h1 class="mt-1 text-4xl font-black">Criar conta</h1>

    <%= form_with model: @user, url: registration_path, class: "mt-6 space-y-4" do |form| %>
      <%= form.email_field :email, placeholder: "email", class: "w-full rounded-md border border-[#17201d]/15 px-4 py-3 font-bold" %>
      <%= form.password_field :password, placeholder: "senha", class: "w-full rounded-md border border-[#17201d]/15 px-4 py-3 font-bold" %>
      <%= form.password_field :password_confirmation, placeholder: "confirmar senha", class: "w-full rounded-md border border-[#17201d]/15 px-4 py-3 font-bold" %>
      <%= form.submit "Comecar", class: "w-full rounded-md bg-[#17201d] px-4 py-3 font-black text-white" %>
    <% end %>

    <%= link_to "Ja tenho conta", new_session_path, class: "mt-4 block text-center text-sm font-bold text-[#1f7a8c]" %>
  </div>
</section>
